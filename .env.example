# PostgreSQL connection string
DATABASE_URL=postgresql://hs_user:CHANGE_ME@localhost:5432/hs_muebles

# Admin panel auth — задай свои значения!
ADMIN_PASSWORD=CHANGE_ME
ADMIN_SECRET=CHANGE_ME_32_CHARS_RANDOM_STRING

# Express port (не менять — Nginx проксирует сюда)
PORT=4000

# ─── Заявки из корзины (/api/order) ───────────────────────────────────────────
# Оба канала опциональны: канал работает, если заполнены его переменные.
# Если не настроен ни один — endpoint вернёт 503 (заявка попадёт только в логи).

# Telegram: создай бота через @BotFather, chat_id узнай через @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP): например Gmail с app-password или почта хостера
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Куда слать заявки (по умолчанию SMTP_USER) и от кого
ORDER_EMAIL_TO=
ORDER_EMAIL_FROM=
