{
  "name": "site_hs",
  "version": "1.0.0",
  "description": "HS Muebles — modern minimalist furniture store (ES/EN)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:seo": "vite build --config vite.config.vps.js && node scripts/prerender.mjs && node scripts/generate-sitemap.mjs",
    "preview": "vite preview --port 3000",
    "shot": "node screenshot.mjs",
    "catalog:pull": "node scripts/pull-catalog.mjs",
    "deploy:dist": "node scripts/deploy-dist.mjs",
    "verify": "npm run lint && npm test",
    "deploy:seo": "npm run verify && npm run catalog:pull && npm run build:seo && npm run deploy:dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "express-rate-limit": "^8.5.2",
    "gsap": "^3.12.5",
    "lenis": "^1.1.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "vitest": "^4.1.8"
  }
}
